{
  "name": "@anorvis/os",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Local-first Anorvis OS backend and LLM Wiki engine.",
  "exports": {
    "./agent-process": "./src/core/agent/process.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun src/platform/gateway/server.ts",
    "test": "bun test tests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:wiki": "bun src/llm-wiki/lint.ts",
    "check": "bun run test && bun run typecheck && bun run lint"
  },
  "dependencies": {
    "effect": "3.21.2",
    "hono": "^4.12.28",
    "markdownlint": "0.41.0",
    "snaptrade-typescript-sdk": "10.0.18"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/bun": "1.3.14",
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.1",
    "typescript-language-server": "^5.3.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0",
    "brace-expansion": "5.0.6"
  }
}
